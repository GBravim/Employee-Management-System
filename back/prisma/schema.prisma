generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Employee {
  id        Int      @id @default(autoincrement())
  fullName  String
  cpf       String   @unique
  email     String
  hireDate  DateTime
  salary    Float
  active    Boolean  @default(true)

  department   Department @relation(fields: [departmentId], references: [id])
  departmentId Int

  position     Position   @relation(fields: [positionId], references: [id])
  positionId   Int
}

model Department {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]
}

model Position {
  id        Int        @id @default(autoincrement())
  title     String
  employees Employee[]
}

model User {
  id       Int    @id @default(autoincrement())
  name     String
  email    String @unique
  password String
  role     String @default("ADMIN")
}